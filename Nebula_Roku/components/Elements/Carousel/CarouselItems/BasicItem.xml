<?xml version="1.0" encoding="utf-8" ?>

<component 
    name="BasicItem" 
    extends="Group" 
    xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">

    <script type="text/brightscript" uri="pkg:/source/CarouselConstants.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="BasicItem.brs"/>

    <interface>
        <!-- Paramentros de Entrada -->
        <field id="itemContent" type="node"   onChange="itemContentChanged" />
        <field id="currRect"    type="rect2d" onChange="currRectChanged" />
        <field id="groupHasFocus" type="boolean" onChange="focusPercentChanged"/>
        <field id="focusPercent" type="float" onChange="focusPercentChanged" />
    </interface>

    <children>
        <!-- Fondo negro -->
        <Rectangle id="theRect" color="#000000">

             <!-- Imagen item -->
            <Poster 
                id="imageItem"
                translation="[0, 0]"
                loadDisplayMode="scaleToZoom"/>

            <LayoutGroup
                id="programTitleByError"
                layoutDirection="vert"
                horizAlignment="center"
                vertAlignment="center"
                visible="false" >
                <Label 
                    id="programTitle"
                    wrap="true"
                    maxLines="3"
                    vertAlign="center"
                    horizAlign="center" />
            </LayoutGroup>

            <Group
                id="metadataGroup"
                visible="false">

                <!-- NUEVO: Poster de gradiente por encima de imageItem y por debajo de los labels de metadata. -->
                <Poster
                    id="metadataGradient"
                    uri="pkg:/images/shared/gradient_bg.png"
                    loadDisplayMode="scaleToFill" />

                <!-- NUEVO: Contenedor vertical de labels dentro de metadataGroup para mantener el orden visual. -->
                <LayoutGroup
                    id="metadataLabels"
                    layoutDirection="vert"
                    horizAlignment="left"
                    vertAlignment="bottom"
                    itemSpacings="[1]">
                    <Label
                        id="title"
                        wrap="true"
                        maxLines="2"
                        visible="false"
                        lineSpacing="2"
                        font="font:TinySystemFont"/>

                    <Label
                        id="category"
                        wrap="false"
                        maxLines="1"
                        visible="false"
                        font="font:TinySystemFont"/>

                    <Label
                        id="dateTime"
                        wrap="false"
                        maxLines="1"
                        visible="false"
                        font="font:TinySystemFont"/>
                </LayoutGroup>
            </Group>

            <LayoutGroup
                id="progressContainer"
                layoutDirection="horiz"
                horizAlignment="left"
                vertAlignment="top">
                <Rectangle id="progressLeft" height="3"/>
                <Rectangle id="progressRight" height="3"/>
            </LayoutGroup>
    
            <Rectangle id="opacityLayout" color="#000000" opacity="0.33" translation="[0,0]" />
        </Rectangle>
    </children>
</component>
