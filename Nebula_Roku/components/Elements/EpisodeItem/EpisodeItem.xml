<?xml version="1.0" encoding="utf-8" ?>
<component
  name="EpisodeItem"
  extends="Group"
  xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">

  <script type="text/brightscript" uri="EpisodeItem.brs" />

  <script type="text/brightscript" uri="pkg:/source/Utils.brs" />

  <interface>
    <!-- Ancho del item para ocupar toda la pantalla disponible. -->
    <field id="widthContainer" type="integer" value="1280" onChange="onLayoutChanged" />
    <!-- Imagen del episodio que llega como objeto para resolver URL con getImageUrl. -->
    <field id="image" type="assocarray" onChange="onEpisodeInputChanged" />
    <!-- Sinopsis del episodio. -->
    <field id="synopsis" type="string" onChange="onEpisodeInputChanged" />
    <!-- Duración formateada del episodio. -->
    <field id="formattedDuration" type="string" onChange="onEpisodeInputChanged" />
    <!-- Flag para decidir si se muestra el ícono playImage. -->
    <field id="play" type="boolean" value="false" onChange="onEpisodeInputChanged" />
    <!-- Título compuesto del episodio. -->
    <field id="title" type="string" onChange="onEpisodeInputChanged" />
    <!-- Nombre del programa padre para mostrar sobre la imagen. -->
    <field id="programTitle" type="string" onChange="onEpisodeInputChanged" />
    <!-- Índice del fallback de poster recibido desde EmissionsScreen. -->
    <field id="index" type="integer" value="1" onChange="onEpisodeInputChanged" />
     <!-- Flag para activar fondo oscuro cuando el item está seleccionado. -->
    <field id="isFocused" type="boolean" value="false" onChange="onFocusStateChanged" />
  </interface>

  <children>
    <!-- Fondo de foco para resaltar todo el item con negro semitransparente. -->
    <Rectangle
      id="focusBackground"
      visible="false"
      color="0x0000004D" />

    <!-- Layout horizontal principal del episodio. -->
    <LayoutGroup
      id="episodeContainer"
      layoutDirection="horiz"
      horizAlignment="left"
      vertAlignment="top"
      itemSpacings="[40]">

      <!-- Contenedor superpuesto para poster, play y duración. -->
      <Group id="episodeMedia">
        <!-- Imagen principal del episodio. -->

        <Poster
          id="imageNotFound"
          loadDisplayMode="scaleToZoom"
          uri="pkg:/images/shared/show_image_empty_1.jpg"/>

        <Label
          id="emissionTitleOverlay"
          text=""
          wrap="true"
          maxLines="3"
          horizAlign="center"
          vertAlign="center"
          color="0xFFFFFFFF"
          font="font:MediumBoldSystemFont" />

        <Poster
          id="emissionImage"
          loadDisplayMode="scaleToZoom"/>

        <!-- Ícono play superpuesto al centro de emissionImage. -->
        <!-- Inicia oculto y se muestra solo cuando play=true. -->
        <Poster
          id="playImage"
          visible="false"
          uri="pkg:/images/shared/play_circle.png" />

        <!-- Grupo de tiempo superpuesto abajo a la derecha de emissionImage. -->
        <Rectangle
          id="episodeTimeGroup"
          width="50"
          height="30"
          color="0x000000FF">
          <Label
            id="episodeTime"
            text="40m"
            color="0xF98C00"
            horizAlign="center"
            vertAlign="center"
            width="50"
            height="30"
            font="font:TinySystemFont" />
        </Rectangle>
      </Group>

      <!-- Columna de información del episodio con altura variable. -->
      <LayoutGroup
        id="episodeInfo"
        layoutDirection="vert"
        horizAlignment="left"
        vertAlignment="top"
        itemSpacings="[10]">

        <Rectangle height="20">
        </Rectangle>

        <!-- Título del episodio con tipografía grande. -->
        <Label
          id="episodeTitle"
          text=""
          wrap="true"
          maxLines="2"
          font="font:LargeBoldSystemFont" />

        <!-- Sinopsis del episodio con tipografía menor. -->
        <Label
          id="episodeSynopsis"
          text=""
          wrap="true"
          font="font:SmallSystemFont" />
      </LayoutGroup>
    </LayoutGroup>
  </children>
</component>
