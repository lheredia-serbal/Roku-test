<?xml version="1.0" encoding="utf-8" ?>

<component 
  name="LoginScreen" 
  extends="Group"
  xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">

  <script type="text/brightscript" uri="LoginScreen.brs"/>
  <script type="text/brightscript" uri="pkg:/source/Utils/i18nUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils/RetryUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Storage.brs" />
  <script type="text/brightscript" uri="pkg:/source/ResultCodes.brs" />
  <script type="text/brightscript" uri="pkg:/source/Enums.brs" />

  <script type="text/brightscript" uri="pkg:/source/Services/DomainManager.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Retry.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ErrorManager.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ErrorCode.brs" />

  <script type="text/brightscript" uri="pkg:/source/Services/Auth.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ActionLogs.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Health.brs" />

  <interface>
    <!-- Paramentros de Entrada -->
    <field id="loading" type="node" />
    <field id="onFocus" type="boolean" value="false" onChange="initFocus" />
    
    <!-- Paramentros de Salida -->
    <field id="finished" alwaysnotify="true" type="boolean" value="false" onChange="onFinished" />
  </interface>
  
  <children>
    <!-- Contenedor principal centrado -->
    <LayoutGroup 
      id="mainContainer" 
      layoutDirection="vert"
      horizAlignment="custom"
      vertAlignment="top">

      <!-- Título principal para elegir el método de inicio de sesión -->
      <Label
        id="loginMethodTitle"
        font="font:LargeBoldSystemFont"
        horizAlign="center" />

      <!-- Contenedor visual del switch de método de login -->
      <Rectangle
        id="loginMethodSwitch"
        color="#233A6AFF"
        blendColor="#233A6AFF">
        <!-- Segmento resaltado para la opción activa (izquierda) -->
        <Rectangle
          id="loginMethodSwitchSelected"
          color="#2FA5E3FF"
          blendColor="#2FA5E3FF" />
        <!-- Texto de la opción de acceso con teléfono -->
        <Label
          id="loginMethodPhone"
          focusable="true"
          font="font:MediumBoldSystemFont"
          horizAlign="center"
          vertAlign="center" />
        <!-- Texto de la opción de acceso con teclado -->
        <Label
          id="loginMethodKeyboard"
          focusable="true"
          font="font:MediumBoldSystemFont"
          horizAlign="center"
          vertAlign="center" />
      </Rectangle>

      <Group id="credentialsContainer">
        <!-- Label de Usuario -->
        <Label
          id="email"
          font="font:SmallSystemFont"
          horizAlign="left" />

        <!-- Campo de entrada para usuario -->
        <TextEditBox
          id="userField"/>

        <!-- Label de Contraseña -->
        <Label 
          id="passwordLabel"
          font="font:SmallSystemFont"
          horizAlign="left" />

        <!-- Campo de entrada para contraseña -->
        <TextEditBox
          id="passwordField"
          secureMode="true"/>

        <Group id="buttonContainer">
          <LayoutGroup
            layoutDirection="horiz"
            horizAlignment="center"
            vertAlignment="top"
            itemSpacings="[20]"> 
            <!-- Botón de Ingresar -->
            <QvButton 
              id="prevButton"
              focusable="true"
              disable="true" />
            <QvButton 
              id="nextButton"
              focusable="true" />
          </LayoutGroup>

        </Group>

        <Keyboard id="keyboard" />
      </Group>
    </LayoutGroup>

    <!-- Logo -->
    <Poster
      id="logo"
      loadDisplayMode="scaleToFit"
      uri="pkg:/images/client/logo.png" />

    <Group id="qrContainer" visible="false">
      <!-- Título de pasos para completar el login desde otro dispositivo -->
      <Label
        id="phoneInstructionsTitle"
        font="font:LargeBoldSystemFont" />

      <!-- Paso 1 -->
      <Label id="step1Badge" font="font:MediumBoldSystemFont" horizAlign="center" />
      <Label id="step1Text" font="font:MediumSystemFont" />
      <Label id="qrShortUrlLabel" font="font:MediumBoldSystemFont" />

      <!-- Paso 2 -->
      <Label id="step2Badge" font="font:MediumBoldSystemFont" horizAlign="center" />
      <Label id="step2Text" font="font:MediumSystemFont" />
      <Label id="activationCodeLabel" font="font:LargeBoldSystemFont" />

      <!-- Paso 3 -->
      <Label id="step3Badge" font="font:MediumBoldSystemFont" horizAlign="center" />
      <Label id="step3Text" font="font:MediumSystemFont" />

      <!-- Fondo para el QR y su imagen remota -->
      <Rectangle id="qrCodeBackground" color="#F2F2F2FF">
        <Poster
          id="qrCodePoster"
          loadDisplayMode="scaleToFit" />
      </Rectangle>

      <!-- Botón para validar el proceso de activación -->
      <QvButton id="validatePhoneButton" focusable="true" />
    </Group>
  </children>
</component>
