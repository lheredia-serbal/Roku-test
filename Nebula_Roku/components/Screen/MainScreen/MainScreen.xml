<?xml version="1.0" encoding="utf-8" ?>

<component 
  name="MainScreen" 
  extends="Group" 
  xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">

  <script type="text/brightscript" uri="MainScreen.brs" />
  <script type="text/brightscript" uri="pkg:/source/StreamingConstants.brs" />
  <script type="text/brightscript" uri="pkg:/source/Storage.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils/i18nUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils/DateFunctions.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils/RetryUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/CarouselConstants.brs" />
  <script type="text/brightscript" uri="pkg:/source/Enums.brs" />

  <script type="text/brightscript" uri="pkg:/source/Services/Channels.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ContentViews.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Menu.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ParentalControl.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Platforms.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/AutoUpgrade.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Streamings.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Programs.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Watch.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ActionLogs.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/DomainManager.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Retry.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ErrorManager.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ErrorCode.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Health.brs" />
  
  <interface>
    <!-- Paramentros de Entrada -->
    <field id="loading" type="node" />
    <field id="onFocus" type="boolean" value="false" onChange="initFocus" />
    <field id="loadData" type="boolean" value="false" onChange="initData" />
    
    <!-- Paramentros de entrada/Salida -->
    <field id="logout" alwaysnotify="true" type="boolean" value="false" onChange="onLogoutChange" />
    
    <!-- Paramentros de Salida -->
    <field id="streaming" type="string" />
    <field id="detail" type="string" />
    <!-- Salida para abrir la pantalla de Ver todos con el contexto del carrusel seleccionado. -->
    <field id="viewAll" type="string" />
    <field id="setting" type="boolean" value="false"/>
    <field id="search" type="boolean" value="false"/>
    <field id="pendingStreamingSession" type="string" />
    <field id="onChangeProfile" type="boolean" value="false" />
    <field id="openGuide" type="boolean" value="false"/>
    <field id="onExit" type="boolean" value="false"/>
    <field id="forceExit" type="boolean" value="false" />
  </interface>

  <children>
    <Poster 
      id="programImageBackground" 
      loadDisplayMode="scaleToZoom"
      uri="pkg:/images/client/info_gradient.png" />

    <Poster 
      id="infoGradient" 
      loadDisplayMode="scaleToFit"
      uri="pkg:/images/client/info_gradient.png" />

    <!-- Contenedor dedicado para NewsItem en posición absoluta (0,0). -->
    <Group id="newsContainer" translation="[0, 0]" />

    <!-- Fondo de noticias a pantalla completa, por encima de News y por debajo de carousels/menu. -->
    <Poster
      id="newsBackgroundPoster"
      loadDisplayMode="scaleToFill"
      uri="pkg:/images/shared/news_gradient.png" />

    <!-- Poster inferior ubicado por encima de newsContainer y por debajo de carousels. -->
    <Poster
      id="bottomGradientPoster"
      loadDisplayMode="scaleToFill"
      uri="pkg:/images/shared/gradient_bg.png" />

    <!-- Overlay de texto e indicadores de News, separado del componente NewsItem para mejorar fluidez de animación. -->
    <Group id="newsOverlay" translation="[0, 0]">
      <!-- Título principal de la noticia activa, siempre por encima del carrusel de News. -->

      <ShadowLabel
        id="newsTitle"
        horizAlign="left"
        vertAlign="bottom"
        wrap="true"
        maxLines="3"
        font="font:LargeBoldSystemFont" />

      <!-- Contenedor horizontal de dots para reflejar el índice actual del carrusel News. -->
      <LayoutGroup
        id="dotsContainer"
        layoutDirection="horiz"
        horizAlign="center"
        itemSpacings="[14]" />
    </Group>

    <!-- Contenedor para múltiples carouseles y foco -->
    <Group id="carousels" translation="[0, 120]">
      <Group id="carouselContainer" translation="[50, 20]"/>

      <SelectionBox id="selectedIndicator" visible="false"/>
    </Group>

    <!-- Program Container -->
    <ProgramSummary 
      id="programInfo" 
      visible="false"/>
      
    <!-- Contenedor para Error que no hay contenido -->
    <LayoutGroup 
      id="withoutContentLayoutGroup"
      visible="false"
      layoutDirection="vert"
      horizAlignment="center"
      vertAlignment="center"
      itemSpacings="[40]">
      <Label
        id="withoutContentTitle"
        visible="true"
        wrap="false" 
        maxLines="1" 
        horizAlign="center"
        font="font:MediumSystemFont" />

      <Label
        id="withoutContentMessage"
        visible="true"
        wrap="true" 
        maxLines="3" 
        horizAlign="center"
        font="font:SmallSystemFont" />
    </LayoutGroup>

    <!--  Menu contairner -->
    <Menu id="myMenu" />

    <!-- Logo -->
    <Poster
      id="mainLogo"
      width="200" 
      height="100"
      loadWidth="200"
      loadHeight="100"
      visible="false"
      translation="[0, 0]"
      loadDisplayMode="scaleToFit"/>

    <!-- Animación para desplazar carouselContainer en 0.5 segundos al navegar desde News hacia abajo. -->
    <Animation
      id="carouselContainerMoveAnimation"
      duration="0.2"
      repeat="false"
      optional="true"
      easeFunction="linear">
      <!-- Interpolador vectorial que actualiza translation de carouselContainer. -->
      <Vector2DFieldInterpolator
        id="carouselContainerMoveInterpolator"
        fieldToInterp="carouselContainer.translation"
        key="[0.0, 1.0]"
        keyValue="[[0.0, 0.0], [0.0, 0.0]]" />
    </Animation>

    <!-- Animación reutilizable para transicionar opacidad del nodo superior del carrusel en 0.5 segundos. -->
    <Animation
      id="focusUpOpacityAnimation"
      duration="0.5"
      repeat="false"
      optional="true"
      easeFunction="linear">
      <!-- Interpolador de opacidad cuyo destino se configura dinámicamente en MainScreen.brs. -->
      <FloatFieldInterpolator
        id="focusUpOpacityInterpolator"
        fieldToInterp=""
        key="[0.0, 1.0]"
        keyValue="[1.0, 1.0]" />
    </Animation>
    
    <Label
        id="nameOrganization"
        visible="false"
        wrap="false" 
        maxLines="3" 
        horizAlign="center"
        font="font:SmallSystemFont" />
    
    <!-- Timers -->
    <Timer id="programTimer" repeat="false" duration="0.5"/>
  </children>
</component>
