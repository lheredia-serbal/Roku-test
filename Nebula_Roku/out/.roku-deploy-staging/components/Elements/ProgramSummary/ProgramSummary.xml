<?xml version="1.0" encoding="utf-8" ?>

<component 
  name="ProgramSummary" 
  extends="Group" 
  xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">
  
  <script type="text/brightscript" uri="ProgramSummary.brs"/>
  <script type="text/brightscript" uri="pkg:/source/Utils/DateFunctions.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils/i18nUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils.brs" />

  <interface>
    <!-- Paramentros de Entrada -->
    <field id="width" type="integer" value="0"/>
    <field id="program" type="string" value="" onChange="changeProgram" />
    <field id="initConfig" type="boolean" value="false" onChange="initConfig" />
  </interface>
  
  <children>
    <LayoutGroup 
      id="programContainer"
      layoutDirection="vert"
      horizAlignment="left"
      vertAlignment="top"
      itemSpacings="[0]">
    </LayoutGroup>

    <!-- Animations -->
    <Animation
        id="liveAnimation"
        duration="2"
        repeat="true"
        optional="true"
        easeFunction="linear" >
    </Animation>

  </children>
</component>
