<?xml version="1.0" encoding="utf-8" ?>

<component 
  name="LoginScreen" 
  extends="Group"
  xsi:noNamespaceSchemaLocation="https://devtools.web.roku.com/schema/RokuSceneGraph.xsd">

  <script type="text/brightscript" uri="LoginScreen.brs"/>
  <script type="text/brightscript" uri="pkg:/source/Utils/i18nUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils/RetryUtils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
  <script type="text/brightscript" uri="pkg:/source/Storage.brs" />
  <script type="text/brightscript" uri="pkg:/source/ResultCodes.brs" />
  <script type="text/brightscript" uri="pkg:/source/Enums.brs" />

  <script type="text/brightscript" uri="pkg:/source/Services/DomainManager.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Retry.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ErrorManager.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ErrorCode.brs" />

  <script type="text/brightscript" uri="pkg:/source/Services/Auth.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/ActionLogs.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Health.brs" />
  <script type="text/brightscript" uri="pkg:/source/Services/Installation.brs" />

  <interface>
    <!-- Paramentros de Entrada -->
    <field id="loading" type="node" />
    <field id="onFocus" type="boolean" value="false" onChange="initFocus" />
    
    <!-- Paramentros de Salida -->
    <field id="finished" alwaysnotify="true" type="boolean" value="false" onChange="onFinished" />
  </interface>
  
  <children>
    <!-- Contenedor principal centrado -->
    <LayoutGroup 
      id="mainContainer" 
      layoutDirection="vert"
      horizAlignment="custom"
      vertAlignment="top">

      <!-- Título principal para elegir el método de inicio de sesión -->
      <ShadowLabel
        id="loginMethodTitle"
        font="font:LargeBoldSystemFont"
        horizAlign="center" 
        vertAlign="top"/>

      <LayoutGroup id="loginMethodSwitchLayout" layoutDirection="vert" horizAlignment="custom" vertAlignment="top">

        <!-- Contenedor visual del switch de método de login -->
        <Poster
          id="loginMethodSwitch"
          loadDisplayMode="stretch"
          loadDisplayMode="scaleToFill"
          uri="pkg:/images/client/login-select-background.png" > 
          <Poster
            id="loginMethodSwitchSelected"
            loadDisplayMode="stretch"
            loadDisplayMode="scaleToFill"
            uri="pkg:/images/client/login-select.png" />

          <ShadowLabel
            id="loginMethodPhone"
            focusable="true"
            font="font:SmallestBoldSystemFont"
            horizAlign="center"
            vertAlign="center" />
          <ShadowLabel
            id="loginMethodKeyboard"
            focusable="true"
            font="font:SmallestBoldSystemFont"
            horizAlign="center"
            vertAlign="center" />
         </Poster>
      </LayoutGroup>

      <LayoutGroup id="credentialsContainer" layoutDirection="vert" horizAlignment="custom" vertAlignment="top">
        <!-- Label de Usuario -->
        <Label
          id="email"
          font="font:SmallSystemFont"
          horizAlign="left" />

        <!-- Campo de entrada para usuario -->
        <TextEditBox
          id="userField"/>

        <!-- Label de Contraseña -->
        <Label 
          id="passwordLabel"
          font="font:SmallSystemFont"
          horizAlign="left" />

        <!-- Campo de entrada para contraseña -->
        <TextEditBox
          id="passwordField"
          secureMode="true"/>

        

        <Group id="buttonContainer">
          <LayoutGroup
            layoutDirection="horiz"
            horizAlignment="center"
            vertAlignment="top"
            itemSpacings="[20]"> 
            <!-- Botón de Ingresar -->
            <QvButton 
              id="prevButton"
              focusable="true"
              disable="true" />
            <QvButton 
              id="nextButton"
              focusable="true" />
          </LayoutGroup>

        </Group>

        <Keyboard id="keyboard" />
      </LayoutGroup>
    </LayoutGroup>

    <!-- Logo -->
    <Poster
      id="logo"
      loadDisplayMode="scaleToFit"
      uri="pkg:/images/client/logo.png" />

    <Group id="qrContainer" visible="false">
      <!-- Título de pasos para completar el login desde otro dispositivo -->
      <Label
        id="phoneInstructionsTitle"
        font="font:MediumBoldSystemFont" />

      <!-- Paso 1 -->
      <Poster id="step1BadgePoster" loadDisplayMode="scaleToFit" uri="pkg:/images/shared/ball_gray.png" />
      <ShadowLabel id="step1Badge" font="font:SmallestBoldSystemFont" horizAlign="center" vertAlign="center" text="1"/>
      <ShadowLabel id="step1Text" font="font:SmallSystemFont"  />
      <ShadowLabel id="qrShortUrlLabel" font="font:SmallBoldSystemFont" />

      <!-- Paso 2 -->
      <Poster id="step2BadgePoster" loadDisplayMode="scaleToFit" uri="pkg:/images/shared/ball_gray.png" />
      <ShadowLabel id="step2Badge" font="font:SmallestBoldSystemFont" horizAlign="center" vertAlign="center" text="2" />
      <ShadowLabel id="step2Text" font="font:SmallSystemFont" />
      <ShadowLabel id="activationCodeLabel" font="font:LargeBoldSystemFont" />

      <!-- Paso 3 -->
      <Poster id="step3BadgePoster" loadDisplayMode="scaleToFit" uri="pkg:/images/shared/ball_gray.png" />
      <ShadowLabel id="step3Badge" font="font:SmallestBoldSystemFont" horizAlign="center" vertAlign="center" text="3" />
      <ShadowLabel id="step3Text" font="font:SmallSystemFont" />

      <!-- Fondo para el QR y su imagen remota -->
      <Rectangle id="qrCodeBackground" color="#F2F2F2FF">
        <Poster
          id="qrCodePoster"
          loadDisplayMode="scaleToFit" />
      </Rectangle>

      <!-- Botón para validar el proceso de activación -->
      <QvButton id="validatePhoneButton" focusable="true" />
    </Group>
  </children>
</component>
